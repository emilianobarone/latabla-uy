<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.emilianobarone.latabla-daily</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/emilianobarone24/Desktop/FutbolUY/run_daily.sh</string>
    </array>

    <!-- 13:00 todos los días. NO se cruza con Supermatch (02:55) ni PawUp (03:00).
         Si la Mac está dormida a esa hora, launchd lo corre al despertar. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>13</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/emilianobarone24/Desktop/FutbolUY/logs/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/emilianobarone24/Desktop/FutbolUY/logs/launchd.err.log</string>
</dict>
</plist>
